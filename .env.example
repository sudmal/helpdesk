APP_NAME="HelpDesk"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://helpdesk.example.com

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# База данных
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=helpdesk
DB_USERNAME=helpdesk
DB_PASSWORD=secret

# Redis (очереди + кэш)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis
SESSION_DRIVER=database
SESSION_LIFETIME=480

# Почта
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=helpdesk@example.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=helpdesk@example.com
MAIL_FROM_NAME="${APP_NAME}"

# Telegram Bot
TELEGRAM_BOT_TOKEN=

# LANBilling API
LANBILLING_URL=
LANBILLING_LOGIN=
LANBILLING_PASSWORD=

# Хранилище файлов (local или s3)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=
# AWS_BUCKET=
